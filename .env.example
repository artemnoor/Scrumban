LOG_LEVEL=debug
NODE_ENV=development
DEPLOYMENT_TARGET=local
POSTGRES_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/scrumbun
DATABASE_APPLY_STRATEGY=push
DATABASE_SSL_MODE=disable
DATABASE_SSL_ROOT_CERT_PATH=
API_PORT=4000
WEB_PORT=5173
WEB_ORIGIN=http://localhost:5173
VITE_API_URL=/api
VITE_LOG_LEVEL=debug
TRUST_PROXY=false
SESSION_COOKIE_NAME=scrumbun_session
SESSION_COOKIE_SECRET=replace-me-with-a-long-random-secret
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@scrumbun.local
SMTP_FROM_NAME=Scrumbun
UPLOAD_STORAGE_DRIVER=local
UPLOAD_LOCAL_DIRECTORY=./data/uploads
