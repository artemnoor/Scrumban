LOG_LEVEL=info
NODE_ENV=production
DEPLOYMENT_TARGET=yandex-cloud

API_PORT=4000
WEB_ORIGIN=https://app.example.com
APP_DOMAIN=app.example.com
VITE_API_URL=/api
VITE_LOG_LEVEL=info

TRUST_PROXY=true
SESSION_COOKIE_NAME=scrumbun_session
SESSION_COOKIE_SECRET=replace-me-with-a-long-random-secret
SESSION_COOKIE_DOMAIN=app.example.com
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=true

DATABASE_URL=postgresql://app_user:replace-me@c-<cluster-host>.rw.mdb.yandexcloud.net:6432/scrumbun?sslmode=verify-full&sslrootcert=/run/secrets/yandex-cloud-postgres-ca.crt
DATABASE_APPLY_STRATEGY=migrate-deploy
DATABASE_SSL_MODE=verify-full
DATABASE_SSL_ROOT_CERT_PATH=/run/secrets/yandex-cloud-postgres-ca.crt
DATABASE_SSL_ROOT_CERT_PATH_HOST=./certs/yandex-cloud-postgres-ca.crt
DATABASE_SSL_ROOT_CERT_PATH_CONTAINER=/run/secrets/yandex-cloud-postgres-ca.crt

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=replace-me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Scrumbun

UPLOAD_STORAGE_DRIVER=local
UPLOAD_LOCAL_DIRECTORY=/app/data/uploads

YC_REGISTRY_HOST=cr.yandex
YC_REGISTRY_ID=replace-with-registry-id
IMAGE_TAG=latest
WEB_PUBLIC_PORT=8080
DEPLOY_HOST=app.example.com
DEPLOY_USER=ubuntu
DEPLOY_PATH=/opt/scrumbun
TLS_CERT_PATH=/etc/letsencrypt/live/app.example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/app.example.com/privkey.pem
